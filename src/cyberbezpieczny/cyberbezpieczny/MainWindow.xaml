<Window x:Class="cyberbezpieczny.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:cyberbezpieczny.ViewModels"
        xmlns:v="clr-namespace:cyberbezpieczny.Views"
        Title="Cyberbezpieczny" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:MenuViewModel}">
            <v:MenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:GameViewModel}">
            <v:GameView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FirewallViewModel}">
            <v:FirewallView/>
        </DataTemplate>
    </Window.Resources>

    <ContentControl Content="{Binding CurrentView}"/>

</Window>