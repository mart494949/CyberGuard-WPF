<UserControl x:Class="cyberbezpieczny.Views.FirewallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#0F2027" Offset="0.0"/>
                <GradientStop Color="#203A43" Offset="0.5"/>
                <GradientStop Color="#2C5364" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Opacity="0.05">
            <Border.Background>
                <DrawingBrush Viewport="0,0,20,20" ViewportUnits="Absolute" TileMode="Tile">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="Cyan">
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <RectangleGeometry Rect="0,0,1,1" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Border.Background>
        </Border>

        <Border VerticalAlignment="Bottom" Height="4" Background="#FF5252" 
                Margin="0,0,0,50" Opacity="0.6" SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="Red" BlurRadius="20" ShadowDepth="0"/>
            </Border.Effect>
        </Border>

        <TextBlock Text="SEKTOR FILTRACJI DANYCH" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                   Foreground="#FF5252" Opacity="0.4" Margin="0,0,0,30" FontSize="10"/>

        <ItemsControl ItemsSource="{Binding Packets}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Image Source="{Binding ImagePath}" Width="60" Height="60" Cursor="Hand">
                            <Image.Effect>
                                <DropShadowEffect ShadowDepth="2" Direction="270" Color="Black" Opacity="0.5" BlurRadius="5"/>
                            </Image.Effect>
                            <Image.InputBindings>
                                <MouseBinding Gesture="LeftClick" 
                                              Command="{Binding DataContext.RemovePacketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                              CommandParameter="{Binding}" />
                            </Image.InputBindings>
                        </Image>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Grid Visibility="{Binding ShowGameOver, Converter={StaticResource BooleanToVisibilityConverter}}" 
      Background="#CC000000" 
      d:IsHidden="True">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="600">

                <TextBlock Text="SYSTEM ZAINFEKOWANY!" 
                   FontSize="40" 
                   Foreground="#FF4444" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>

                <TextBlock Text="{Binding Wynik, StringFormat='Twój Wynik: {0}'}" 
                   FontSize="30" 
                   Foreground="White" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,40"/>

                <Border Background="#33FFFFFF" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <TextBlock Text="PORADA BEZPIECZEŃSTWA:" 
                           Foreground="Yellow" 
                           FontWeight="Bold" 
                           FontSize="18" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding TipText}" 
                           Foreground="White" 
                           FontSize="20" 
                           TextWrapping="Wrap" 
                           TextAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Button Content="WRÓĆ DO MENU" 
                        Click="Button_Click"
                FontSize="20"
                FontWeight="Bold"
                Padding="20,10"
                Margin="0,30,0,0"
                Background="#FF4444"
                Foreground="White"
                BorderThickness="0">
                </Button>

            </StackPanel>
        </Grid>
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" 
                Background="#cc000000" CornerRadius="15" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="Black"/>
            </Border.Effect>

            <StackPanel Width="200">
                <TextBlock Text="WYNIK" Foreground="#AAAAAA" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Score}" Foreground="#00FF99" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FF99" BlurRadius="10" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock Text="STAN SYSTEMU" Foreground="#AAAAAA" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Height="20">
                    <ProgressBar Value="{Binding Lives}" Maximum="100" Minimum="0" BorderThickness="0" Background="#333" Foreground="Red"/>
                    <TextBlock Text="{Binding Lives, StringFormat='{}{0}%'}" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="White" FontSize="10" FontWeight="Bold"/>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>